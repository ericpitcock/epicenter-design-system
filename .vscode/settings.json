{
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/storybook-static/**": true,
    "**/docs/.vitepress/dist/**": true
  },
  "search.exclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/storybook-static/**": true,
    "**/docs/.vitepress/dist/**": true
  },
  "stylelint.validate": ["css", "scss"],
  "stylelint.ignoreDisables": false,
  "stylelint.snippet": ["css", "scss"],
  "files.associations": {
    "**/.stylelintignore": "ignore"
  }
}