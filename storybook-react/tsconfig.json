{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "ES6"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types", "./types"],
    "paths": {
      "@ericpitcock/epicenter-react-components": ["../packages/epicenter-react-components"],
      "@ericpitcock/epicenter-icons-react": ["../packages/epicenter-icons-react"],
      "@ericpitcock/epicenter-icons-react/*": ["../packages/epicenter-icons-react/*"],
      "@ericpitcock/epicenter-icons-vue": ["../packages/epicenter-icons-vue"],
      "@ericpitcock/epicenter-icons-vue/*": ["../packages/epicenter-icons-vue/*"]
    }
  },
  "include": [
    "stories/**/*",
    "types/**/*",
    ".storybook/**/*",
    "vite-env.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}